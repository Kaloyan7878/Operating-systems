#include <err.h>
#include <fcntl.h>
#include <stdbool.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <unistd.h>
int main(int argc, char* argv[])
{
    if (argc != 4) errx(1, "bad args");
    int fdSCL = open(argv[1], O_RDONLY);
    int fdSDL = open(argv[2], O_RDONLY);
    int output = open(argv[3], O_WRONLY | O_TRUNC | O_CREAT, 0666);
    if (fdSCL == -1 || fdSDL == -1 || output == -1) err(1, "cant open");
    uint8_t byte;
    ssize_t readSize;
    while ((readSize = read(fdSCL, &byte, sizeof(byte))) > 0)
    {
        uint8_t mask = (1 << 7);
        for (int i = 0; i < 8; i++)
        {
            uint16_t num;
            if (read(fdSDL, &num, sizeof(num)) == -1) err(1, "cant read");
            if ((byte & mask) == 1)
            {
                if (write(output, &num, sizeof(num)) == -1) err(1, "cant write");
            }
            mask = (mask >> 1);
        }
    }
    if (readSize == -1) err(1, "cant read");

    close(fdSCL);
    close(fdSDL);
    close(output);
    return 0;
}
