#!/bin/bash
#(BIND9 зонални файлове) Дефинирани са понятия за whitespace, FQDN, ресурсни записи от вида <ключ> <TTL> <клас> <тип> <RDATA>,
#SOA записи (еднoредови и многоредови), сериен номер във формат YYYYMMDDTT.

#Напишете шел скрипт, който по подадени имена на зонални файлове променя серийният номер в SOA записа на всеки файл по следния алгоритъм:

#ако датата в серийния номер е по-стара от днешната, новият сериен номер трябва да е от вида днешнадата00
#ако датата в серийния номер е равна на днешната, серийният номер трябва да се увеличи с единица

#Изисквания:

#скриптът трябва да може да обработва и едноредови, и многоредови SOA записи;
#за всеки зонален файл, който не е успял да обработи, скриптът трябва да извежда съобщение за грешка с името на файла,
#лесно обработваемо с текстови инструменти.


today=$(date +%Y%m%d)
for file in "$@"; do
    serial=$(cat "$file" | sed 's/;.*//' | grep -o -E "[ (][0-9]{10} ")
    dateF=$((serial/100))
    if [[ $today -gt $dateF ]]; then
        newSerial="${today}00"
    else
        newSerial=$((serial+1))
    fi
    sed -i "s/$serial/$newSerial/" "$file"
done
